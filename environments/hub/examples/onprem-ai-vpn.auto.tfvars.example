onprem_sites = {
  ai-trivandrum = {
    # Replace with OPNsense WAN public IP or stable DDNS after firewall setup.
    gateway_address = "203.0.113.10"

    # Advertise only the controlled AI VLAN to Azure.
    address_spaces = ["172.16.10.0/24"]
  }
}

onprem_private_dns_zone_name = "onprem.opslora.internal"

onprem_a_records = {
  ai-gateway = "172.16.10.10"
}

