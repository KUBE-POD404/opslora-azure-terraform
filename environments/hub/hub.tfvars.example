subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"

admin_principal_object_ids = [
  "00000000-0000-0000-0000-000000000000"
]

# Opslora currently uses the temporary Tailscale AKS bridge for Azure-to-local
# AI connectivity. Keep Azure native S2S VPN disabled unless/until the permanent
# OPNsense/VLAN/IPsec architecture is explicitly restored.
enable_vpn_gateway = false

# Optional future site-to-site VPN peers. Keep real values in an untracked secure
# tfvars file or GitHub Actions variables/secrets. Do not commit real shared keys.
# These are ignored while enable_vpn_gateway=false.
onprem_sites = {}
onprem_shared_keys = {}

# Optional stable private DNS contract. Do not point this at the old 172.16.10.x
# VLAN plan while the active architecture is the temporary Tailscale bridge.
onprem_private_dns_zone_name = "onprem.opslora.internal"
onprem_a_records            = {}
