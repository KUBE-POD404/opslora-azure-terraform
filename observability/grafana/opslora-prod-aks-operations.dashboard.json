      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "azure-monitor-oob"
          },
          "queryType": "Azure Log Analytics",
          "subscription": "022f0684-6e55-4dbf-af86-8ea607fe4833",
          "azureLogAnalytics": {
            "dashboardTime": true,
            "query": "KubePodInventory\n| where $__timeFilter(TimeGenerated)\n| where ClusterName == 'aks-opslora-prod-cin-001'\n| where Namespace in ('opslora-app-ns', 'argocd')\n| where PodStatus in ('Failed', 'Pending', 'Unknown')\n| project TimeGenerated, Namespace, Name, PodStatus, ContainerStatus\n| order by TimeGenerated desc\n| take 100",
            "resources": [
              "/subscriptions/022f0684-6e55-4dbf-af86-8ea607fe4833/resourceGroups/rg-opslora-prod-monitoring-cin/providers/Microsoft.OperationalInsights/workspaces/law-opslora-prod-cin-001"
            ],
            "resultFormat": "table",
            "timeColumn": "TimeGenerated"
          }
        }
      ]
